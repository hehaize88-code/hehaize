{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hubbuy-sheet-preview",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./worker/index.js",
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  }
}
